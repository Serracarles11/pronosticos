{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm run build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/internal/cron/sync-football-matches",
      "schedule": "0 6 * * *"
    }
  ]
}
